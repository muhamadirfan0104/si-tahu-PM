rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Production recommendation:
    // Set custom claims from backend/Admin SDK:
    // { role: 'ADMIN' } atau { role: 'KASIR' }
    function claimRole() {
      return signedIn() && request.auth.token.role is string ? request.auth.token.role : '';
    }

    function isAdmin() {
      return signedIn() && claimRole() == 'ADMIN';
    }

    function isKasir() {
      return signedIn() && claimRole() == 'KASIR';
    }

    function ownedByCurrentCashier() {
      return resource.data.kasirAuthUid == request.auth.uid
        || resource.data.userAuthId == request.auth.uid
        || resource.data.dibuatOlehAuthUid == request.auth.uid;
    }

    // User profile. Admin manages all users; cashier can read only own profile if doc id is auth uid.
    match /Pengguna/{userId} {
      allow read: if isAdmin() || (signedIn() && userId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // Master data: admin writes, cashier reads for POS.
    match /Produk/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /HargaJual/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /parameterProduksi/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /Pengaturan/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Operasional admin.
    match /CatatanProduksi/{docId} {
      allow read, write: if isAdmin();
    }
    match /PenyesuaianStok/{docId} {
      allow read, write: if isAdmin();
    }
    match /Pengeluaran/{docId} {
      allow read, write: if isAdmin();
    }
    match /BatchStok/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /RiwayatStok/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    match /RingkasanHarian/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Penjualan: admin full access; cashier can create/read/update their own cashier transactions.
    match /Penjualan/{docId} {
      allow read: if isAdmin() || (isKasir() && ownedByCurrentCashier());
      allow create: if isAdmin() || isKasir();
      allow update: if isAdmin() || (isKasir() && ownedByCurrentCashier());
      allow delete: if isAdmin();
      match /rincian/{rincianId} {
        allow read: if signedIn();
        allow write: if isAdmin() || isKasir();
      }
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
