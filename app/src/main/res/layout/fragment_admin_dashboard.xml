<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_summary_green"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView android:id="@+id/tvSummaryDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" android:textAppearance="@style/TextAppearance.Material3.BodyMedium" />
                <TextView android:id="@+id/tvSummarySales" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium" android:textColor="@color/white" />
                <TextView android:id="@+id/tvSummaryProduction" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="@color/white" />
                <TextView android:id="@+id/tvSummaryExpenses" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
                <TextView android:id="@+id/tvSummaryTransactions" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
                <TextView android:id="@+id/tvSummaryProfit" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="horizontal" android:weightSum="2">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnGoProduction" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Produksi" />
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnGoSales" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Penjualan" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:orientation="horizontal" android:weightSum="2">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnGoStock" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Stok" />
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnNewExpense" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Pengeluaran" />
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Stok kritis" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvLowStock" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:nestedScrollingEnabled="false" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Transaksi terbaru" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvRecentTransactions" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:nestedScrollingEnabled="false" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
