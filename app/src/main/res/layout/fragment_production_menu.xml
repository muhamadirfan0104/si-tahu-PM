<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" app:cardBackgroundColor="@android:color/transparent">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_summary_green" android:orientation="vertical" android:padding="18dp">
                <TextView android:id="@+id/tvProductionTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Produksi hari ini" android:textAppearance="@style/TextAppearance.Material3.BodyMedium" android:textColor="@color/white" />
                <TextView android:id="@+id/tvProductionTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium" android:textColor="@color/white" />
                <TextView android:id="@+id/tvProductionBatch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:textColor="@color/white" />
                <TextView android:id="@+id/tvProductionDerived" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
                <TextView android:id="@+id/tvParameterActive" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
                <TextView android:id="@+id/tvProductionHistoryCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:orientation="vertical">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnBasicProduction" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Produksi Dasar" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnConversion" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Produksi Turunan" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnProductionHistory" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Riwayat Produksi" />
            <com.google.android.material.button.MaterialButton android:id="@+id/btnParameterList" style="@style/Widget.Material3.Button.OutlinedButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:text="Parameter Produksi" />
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="Aktivitas produksi terbaru" android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
        <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvProductionRecent" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:nestedScrollingEnabled="false" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
