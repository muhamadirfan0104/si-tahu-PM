<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F4ED">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentProduction"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F7F4ED"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="124dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:strokeColor="#EAE5D9"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_summary_green"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:id="@+id/tvProductionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Produksi hari ini"
                        android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProductionTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="0 pcs"
                        android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProductionBatch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Masak dasar tercatat: 0"
                        android:textColor="@android:color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvProductionDerived"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Produk olahan tercatat: 0 transaksi"
                        android:textColor="@android:color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvParameterActive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Parameter aktif: 0"
                        android:textColor="@android:color/white"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvProductionHistoryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Riwayat total: 0 catatan"
                        android:textColor="@android:color/white"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Aktivitas terbaru"
                android:textColor="#2D3428"
                android:textSize="17sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProductionRecent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:id="@+id/productionActionScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/floating_menu_overlay"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/productionFabMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="92dp"
        android:gravity="end"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btnProductionHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Riwayat"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/floating_menu_surface"
            app:elevation="6dp"
            app:icon="@android:drawable/ic_menu_recent_history"
            app:iconTint="@color/green_primary" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btnConversion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Produksi Olahan"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/floating_menu_surface"
            app:elevation="6dp"
            app:icon="@android:drawable/ic_menu_rotate"
            app:iconTint="@color/green_primary" />

        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/btnBasicProduction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Produksi Dasar"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/floating_menu_surface"
            app:elevation="6dp"
            app:icon="@android:drawable/ic_menu_upload"
            app:iconTint="@color/green_primary" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabToggleProductionMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Buka menu produksi"
        app:backgroundTint="@color/floating_menu_toggle"
        app:borderWidth="0dp"
        app:elevation="8dp"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@android:color/white" />

    <ProgressBar
        android:id="@+id/progressLoadProduction"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:visibility="gone" />

</FrameLayout>
