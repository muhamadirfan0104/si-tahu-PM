<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F4ED"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FCFBF7"
            app:elevation="0dp">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="?attr/actionBarSize"
                android:paddingHorizontal="8dp"
                app:titleTextColor="#293226" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EAE5D9" />
        </com.google.android.material.appbar.AppBarLayout>

        <include
            android:id="@+id/contentSalesMenu"
            layout="@layout/fragment_sales_menu"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EAE5D9" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNavigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            app:elevation="0dp"
            app:itemRippleColor="#E7EFDC"
            app:itemIconTint="@color/nav_item_selector"
            app:itemTextColor="@color/nav_item_selector"
            app:labelVisibilityMode="labeled" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutQuickSalesMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="168dp"
        android:gravity="end"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuickSalesHistory"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="56dp"
            android:text="Riwayat penjualan"
            android:textColor="@android:color/white"
            app:backgroundTint="#355F3A"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_receipt"
            app:iconTint="@android:color/white"
            app:rippleColor="#33FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuickMarketRecap"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="56dp"
            android:text="Rekap pasar"
            android:textColor="@android:color/white"
            app:backgroundTint="#355F3A"
            app:cornerRadius="28dp"
            app:icon="@drawable/ic_point_of_sale"
            app:iconTint="@android:color/white"
            app:rippleColor="#33FFFFFF" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabQuickSales"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="96dp"
        android:contentDescription="Aksi penjualan"
        app:backgroundTint="#A8C2F0"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="#1D3557" />

</FrameLayout>
