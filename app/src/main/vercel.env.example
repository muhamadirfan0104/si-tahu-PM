# Production backend environment variables
# Jangan simpan secret key di aplikasi Android.

ALLOWED_ORIGIN=https://domain-backend-atau-admin-kamu.example

# Midtrans lama jika masih dipakai
MIDTRANS_IS_PRODUCTION=true
MIDTRANS_SERVER_KEY=isi_server_key_production

# Xendit backend terpisah
XENDIT_MODE=production
XENDIT_SECRET_KEY=isi_secret_key_production
